// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id               String   @id @default(cuid())
  name             String
  description      String
  price            Decimal
  promotionalPrice Decimal?
  imageUrl         String?
  category         String   // "HOTDOG", "DRINK", "PORTION", etc.
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Order {
  id                   String      @id @default(cuid())
  clientName           String
  clientPhone          String
  notes                String?
  paymentStatus        String      @default("PENDING") // "PENDING", "PAID", "FAILED", "REFUNDED"
  orderStatus          String      @default("RECEIVED") // "RECEIVED", "PREPARING", "READY", "DELIVERED"
  total                Decimal
  paymentMethod        String      // "PIX", "CREDIT_CARD"
  pagarmeTransactionId String?     @unique
  qrcodeUrl            String?
  qrcodeCopyPaste      String?
  items                OrderItem[]
  printQueue           PrintQueue?
  
  // Detalhes de entrega
  deliveryType         String      @default("WITHDRAWAL") // "DELIVERY", "WITHDRAWAL"
  deliveryFee          Decimal     @default(0)
  neighborhoodName     String?
  addressStreet        String?
  addressNumber        String?
  addressReference     String?

  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  productName  String
  productPrice Decimal
  quantity     Int
}

model PrintQueue {
  id        String    @id @default(cuid())
  orderId   String    @unique
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  printed   Boolean   @default(false)
  printedAt DateTime?
  createdAt DateTime  @default(now())
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String    // "PERCENTAGE", "FIXED"
  value         Decimal
  minOrderValue Decimal?
  expiresAt     DateTime?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
}

model Neighborhood {
  id          String   @id @default(cuid())
  name        String   @unique
  deliveryFee Decimal
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Registro \u00fanico de configura\u00e7\u00f5es da loja (sempre id = 'singleton')
model StoreSettings {
  id String @id @default("singleton")

  // Dados da loja
  storeName      String @default("Oh my Dog!")
  storePhone     String @default("")
  storeAddress   String @default("")
  storeInstagram String @default("")

  // Controle de status
  isForceClose Boolean @default(false) // Toggle para fechar imediatamente

  // Hor\u00e1rio de funcionamento
  openTime  String @default("17:30")
  closeTime String @default("23:00")
  openDays  String @default("0,2,3,4,5,6") // 0=Dom,1=Seg,...6=S\u00e1b separados por v\u00edrgula

  // Entrega
  deliveryEnabled       Boolean @default(true)
  withdrawalEnabled     Boolean @default(true)
  deliveryBaseFee       Decimal @default(5.00)
  deliveryFeePerKm      Decimal @default(1.50)
  deliveryMaxDistanceKm Decimal @default(10.00)
  estimatedDeliveryTime Int     @default(40) // minutos

  updatedAt DateTime @updatedAt
}
